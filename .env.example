# JioSaavn API Configuration Template

# Port to run the server on (default: 3000)
PORT=3000

# Log level for tracing (options: trace, debug, info, warn, error)
RUST_LOG=info

# Comma-separated list of rotating proxies to bypass JioSaavn IP limits/rate limits
# Example: http://127.0.0.1:8080,http://username:password@proxy.example.com:3128
PROXY_POOL=
